# ─────────────────────────────────────────────
# The Daily Digest — Required Environment Variables
# ─────────────────────────────────────────────
# Copy this file to .env for local testing (never commit .env to git)

# Your Anthropic API key
# Get it at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Your Resend API key
# Get it at: https://resend.com/api-keys
RESEND_API_KEY=re_...

# Who receives the digest
RECIPIENT_EMAIL=you@example.com

# Who it's sent from (must be a verified domain in Resend)
# For testing you can use: onboarding@resend.dev (sends only to your own address)
SENDER_EMAIL=digest@yourdomain.com
